# june1815 environment reference.
#
# This file is auto-generated from src/config/env-keys.ts by
# `npm run gen:env-example`. Do not edit by hand — edit env-keys.ts.
#
# Every key listed here can also live under the equivalent YAML path in
# `june1815.yml`. Precedence: CLI args > process.env > project june1815.yml >
# ~/.config/june1815/june1815.yml > built-in defaults.

# UX mode: interactive (TTY prompts) or headless (no prompts).
# YAML path: mode
JUNE1815_MODE=interactive

# Conversation state and session markers location.
# YAML path: dataDir
JUNE1815_DATA_DIR=~/.local/share/june1815

# HTTP bind address. Use 0.0.0.0 to expose beyond localhost.
# YAML path: server.host
JUNE1815_HOST=127.0.0.1

# HTTP listen port.
# YAML path: server.port
JUNE1815_PORT=7150

# Bearer token required on all /v1/* write endpoints. Auto-generated at first boot if unset.
# YAML path: server.auth.bearerToken
# WARNING: secret value — do not commit a real one to git.
JUNE1815_BEARER_TOKEN=replace-me-with-a-random-32-char-string

# Permit headless installation of `claude` via `npm i -g @anthropic-ai/claude-code`.
# YAML path: claude.autoInstall
JUNE1815_AUTO_INSTALL=false

# Explicit path to the `claude` executable. Overrides PATH lookup.
# YAML path: claude.path
JUNE1815_CLAUDE_PATH=/usr/local/bin/claude

# PTY width. Wider PTY reduces line-wrap noise in the TUI parser.
# YAML path: pty.cols
JUNE1815_PTY_COLS=200

# PTY height. Tall enough to hold reasoning + tool blocks.
# YAML path: pty.rows
JUNE1815_PTY_ROWS=50

# Quiet period in ms before the TUI parser snapshots the screen.
# YAML path: pty.idleQuietMs
JUNE1815_PTY_IDLE_QUIET_MS=10

# pino log level: fatal | error | warn | info | debug | trace.
# YAML path: logger.level
JUNE1815_LOG_LEVEL=info

# Force human-readable log output. Default: true in interactive mode.
# YAML path: logger.pretty
JUNE1815_LOG_PRETTY=true

# Maximum concurrent conversations (each runs its own `claude` child).
# YAML path: limits.maxConversations
JUNE1815_MAX_CONVERSATIONS=8

# Serve the bundled chat UI at `/`. Disabled by default.
# YAML path: ui.enabled
JUNE1815_UI_ENABLED=false

# Override path to the built UI directory. Defaults to dist/ui inside the package.
# YAML path: ui.distDir
JUNE1815_UI_DIST_DIR=/opt/june1815/dist/ui

# Omit Secure flag on the auth cookie so it works over plain HTTP. Set false behind TLS.
# YAML path: ui.cookieInsecure
JUNE1815_UI_COOKIE_INSECURE=true
