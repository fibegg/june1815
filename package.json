{
  "name": "june15",
  "version": "0.0.0",
  "description": "Wrap the Claude CLI's interactive TUI via PTY and expose it as an HTTP app-server (REST + SSE).",
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "pty",
    "tui",
    "app-server",
    "sse",
    "http",
    "agent",
    "ai"
  ],
  "license": "MIT",
  "author": "june15 contributors",
  "homepage": "https://github.com/fibegg/june15#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fibegg/june15.git"
  },
  "bugs": {
    "url": "https://github.com/fibegg/june15/issues"
  },
  "type": "module",
  "workspaces": ["ui"],
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./events": {
      "types": "./dist/server/events.d.ts",
      "import": "./dist/server/events.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "june15": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "june15.example.yml",
    "june15.schema.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node scripts/fix-node-pty.mjs",
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsup",
    "build:ui": "npm --workspace @june15/ui run build",
    "clean": "rm -rf dist coverage .vitest-cache",
    "dev": "tsup --watch",
    "dev:ui": "npm --workspace @june15/ui run dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "alloy": "scripts/run-alloy.sh",
    "gen:env-example": "tsx scripts/gen-env-example.ts",
    "verify": "scripts/verify-package.sh",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "prepublishOnly": "npm run ci"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@hono/node-server": "^1.12.0",
    "@xterm/headless": "^5.5.0",
    "commander": "^12.1.0",
    "hono": "^4.6.0",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
